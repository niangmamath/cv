<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Connexion Administrateur - Ubuntudigit Talent</title>
    <link rel="icon" href="https://res.cloudinary.com/dlqwxsufy/image/upload/v1773144575/Logo_ud_tarj6a.png" type="image/png">
    <link rel="stylesheet" href="/styles.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <meta name="robots" content="noindex, nofollow">
</head>
<body class="auth-page">

    <div class="auth-box">
        <div class="auth-header">
            <a href="/" class="logo">
                <img src="https://res.cloudinary.com/dlqwxsufy/image/upload/v1773144575/Logo_ud_tarj6a.png" alt="Ubuntudigit Talent Logo">
            </a>
            <h2>Accès Administrateur</h2>
            <p>Veuillez vous authentifier pour continuer.</p>
        </div>

        <form action="/admin/login" method="POST">
            <div class="form-group">
                <label for="username">Nom d'utilisateur</label>
                <input type="text" id="username" name="username" placeholder="Votre nom d'utilisateur" required>
            </div>
            <div class="form-group">
                <label for="password">Mot de passe</label>
                <input type="password" id="password" name="password" placeholder="Votre mot de passe" required>
            </div>
            <button type="submit" class="cta-button">Se connecter</button>
        </form>
         <% if (typeof error !== 'undefined' && error) { %>
            <p class="error-message">Identifiants incorrects. Veuillez réessayer.</p>
        <% } %>
    </div>

</body>
</html>
