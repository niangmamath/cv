<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tableau de Bord Administrateur - Ubuntudigit Talent</title>
    <link rel="icon" href="https://res.cloudinary.com/dlqwxsufy/image/upload/v1773144575/Logo_ud_tarj6a.png" type="image/png">
    <link rel="stylesheet" href="/styles.css?v=6">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <meta name="robots" content="noindex, nofollow">
</head>
<body class="dashboard-page admin-dashboard">

    <header class="dashboard-header">
        <div class="logo">
            <img src="https://res.cloudinary.com/dlqwxsufy/image/upload/v1773144575/Logo_ud_tarj6a.png" alt="Ubuntudigit Talent Logo">
            <span>Espace Administrateur</span>
        </div>
        <nav>
            <a href="/logout" class="logout-button"><i class="fas fa-sign-out-alt"></i> Déconnexion</a>
        </nav>
    </header>

    <main class="dashboard-main">
        <div class="dashboard-title">
            <h1><i class="fas fa-tachometer-alt"></i> Tableau de Bord</h1>
            <p>Gestion complète des utilisateurs et de leurs plans.</p>
        </div>

        <div class="user-list-container card">
            <div class="card-header">
                <h2><i class="fas fa-users"></i> Liste des Utilisateurs</h2>
                <div class="user-count">
                    <span class="count-number"><%= users.length %></span> utilisateurs
                </div>
            </div>
            <div class="table-responsive">
                <table class="user-table">
                    <thead>
                        <tr>
                            <th><i class="fas fa-envelope"></i> Email</th>
                            <th><i class="fas fa-user-tag"></i> Rôle</th>
                            <th><i class="fas fa-pencil-alt"></i> Plan Actuel</th>
                            <th><i class="fas fa-chart-bar"></i> Utilisation</th>
                            <th><i class="fas fa-calendar-alt"></i> Inscrit le</th>
                            <th class="actions-column"><i class="fas fa-cogs"></i> Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if(users.length > 0) { %>
                            <% users.forEach(user => { %>
                                <tr>
                                    <td><a href="mailto:<%= user.email %>" title="Envoyer un email à <%= user.username %>"><%= user.email %></a></td>
                                    <td>
                                        <span class="role-badge role-<%= user.role.replace('_', '-') %>">
                                            <i class="fas <%= user.role === 'recruiter' ? 'fa-user-tie' : 'fa-user-graduate' %>"></i>
                                            <%= user.role === 'job_seeker' ? 'Candidat' : 'Recruteur' %>
                                        </span>
                                    </td>
                                    <td>
                                        <span class="plan-badge">
                                            <%= user.plan ? user.plan.name : 'Aucun' %>
                                        </span>
                                    </td>
                                    <td>
                                        <span class="analysis-count <%= (user.analysisCount >= user.maxAnalyses) ? 'limit-reached' : '' %>">
                                            <%= user.analysisCount %> / <%= user.maxAnalyses %>
                                        </span>
                                    </td>
                                    <td><%= new Date(user.createdAt).toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' }) %></td>
                                    <td class="actions-cell">
                                        
                                        <form action="/admin/update-plan" method="POST" class="action-form plan-form">
                                            <input type="hidden" name="userId" value="<%= user._id %>">
                                            <select name="planId" class="plan-select" onchange="this.form.submit()">
                                                <option value="">Changer de plan...</option>
                                                <% plans.forEach(plan => { %>
                                                    <% if (plan.userType === user.role) { %>
                                                        <option value="<%= plan._id %>" <%= (user.plan && user.plan._id.equals(plan._id)) ? 'selected' : '' %>>
                                                            <%= plan.name %>
                                                        </option>
                                                    <% } %>
                                                <% }); %>
                                            </select>
                                        </form>

                                        <form action="/admin/delete-user" method="POST" class="action-form" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet utilisateur ? Cette action est irréversible.');">
                                            <input type="hidden" name="userId" value="<%= user._id %>">
                                            <button type="submit" class="action-btn delete-btn" title="Supprimer l'utilisateur"><i class="fas fa-trash-alt"></i></button>
                                        </form>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr>
                                <td colspan="6" class="no-users-message">Aucun utilisateur n'est actuellement enregistré sur la plateforme.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </main>

<script>
    document.querySelectorAll('.plan-form').forEach(form => {
        form.addEventListener('submit', function() {
            const select = this.querySelector('select');
            // Optionnel: désactiver le select pour éviter un double envoi
            if (select) {
                select.disabled = true;
            }
        });
    });
</script>

</body>
</html>
