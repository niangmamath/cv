<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Analyseur de CV - Ubuntudigit Talent</title>
    <link rel="icon" href="https://res.cloudinary.com/dlqwxsufy/image/upload/v1773144575/Logo_ud_tarj6a.png" type="image/png">
    <link rel="stylesheet" href="/styles.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
</head>
<body class="analyzer-page">
    <header class="main-header">
        <nav>
            <a href="/" class="logo">
                <img src="https://res.cloudinary.com/dlqwxsufy/image/upload/v1773144575/Logo_ud_tarj6a.png" alt="Ubuntudigit Talent Logo">
                <span>Ubuntudigit Talent</span>
            </a>
            <ul class="nav-links">
                <li><a href="/">Accueil</a></li>
                <li><a href="/analyzer">Analyseur</a></li>
                <li><a href="/logout">Déconnexion</a></li>
            </ul>
            <button class="nav-toggle"><i class="fas fa-bars"></i></button>
        </nav>
    </header>

    <div class="container">
        <h1>Analyseur de CV par IA</h1>
        <p class="subtitle">Obtenez un score de compatibilité, des conseils d'amélioration et une version de votre CV optimisée pour le poste.</p>
        
        <div id="user-status-container" class="user-status-container"></div>

        <form id="analysis-form" action="/analyze" method="POST" enctype="multipart/form-data">
            <div class="form-group">
                <label for="jobDescription">Description de l'offre d'emploi</label>
                <textarea id="jobDescription" name="jobDescription" rows="8" placeholder="Copiez et collez ici la description du poste..."></textarea>
                <p style="text-align:center; margin: 1rem 0; color: #777;">OU</p>
                <label for="jobDescriptionFile">Téléversez une description de poste (PDF, TXT)</label>
                <input type="file" id="jobDescriptionFile" name="jobDescriptionFile" accept=".pdf,.txt">
            </div>
            <div class="form-group">
                <label for="cv">Téléverser un CV (PDF)</label>
                <input type="file" id="cv" name="cv" accept=".pdf" required>
            </div>
             <div class="form-group">
                <label for="tone">Choisissez le ton du CV optimisé</label>
                <select id="tone" name="tone">
                    <option value="Professionnel" selected>Professionnel (standard)</option>
                    <option value="Créatif">Créatif</option>
                    <option value="Technique">Technique</option>
                    <option value="Académique">Académique</option>
                </select>
            </div>
            <div class="privacy-notice">
                <i class="fas fa-lock"></i>
                <span>Pour garantir votre confidentialité, vos documents sont analysés de manière sécurisée et ne sont jamais stockés sur nos serveurs.</span>
            </div>
            <button type="submit">Analyser et optimiser mon CV</button>
        </form>

        <div id="results-container" style="display:none;">
            
            <div class="score-wrapper">
                <h2>Score de compatibilité</h2>
                <div class="score-circle">
                    <span id="score-value">0%</span>
                </div>
            </div>

            <div class="keywords-wrapper">
                <h2>Mots-clés ATS recommandés</h2>
                <p id="keywords-result"></p>
            </div>

            <div class="analysis-wrapper">
                <h2>Analyse et Recommandations</h2>
                <div id="analysis-result"></div>
            </div>

            <div class="rewritten-cv-wrapper">
                <h2>Votre CV optimisé</h2>
                <pre id="rewritten-cv-result"></pre>
                <button id="copy-cv-button">Copier le CV</button>
                <button id="download-pdf-button">Télécharger en PDF</button>
            </div>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            checkUserStatus();
        });

        const navToggle = document.querySelector('.nav-toggle');
        const navLinks = document.querySelector('.nav-links');

        navToggle.addEventListener('click', () => {
            navLinks.classList.toggle('active');
        });

        async function checkUserStatus() {
            const statusContainer = document.getElementById('user-status-container');
            const submitButton = document.querySelector('#analysis-form button[type="submit"]');
            const defaultButtonText = 'Analyser et optimiser mon CV';

            try {
                const response = await fetch('/api/user-status');
                if (!response.ok) throw new Error('Could not fetch user status.');
                
                const data = await response.json();
                const { analysisCount, maxAnalyses } = data;
                const remaining = maxAnalyses - analysisCount;

                if (remaining <= 0) {
                    statusContainer.innerHTML = `
                        <p class="limit-reached-message">
                            <i class="fas fa-exclamation-triangle"></i>
                            Vous avez utilisé toutes vos analyses gratuites (${analysisCount}/${maxAnalyses}).
                            <a href="https://wa.me/212783346308" target="_blank">Contactez-nous sur WhatsApp</a> pour passer à un plan supérieur.
                        </p>
                    `;
                    submitButton.disabled = true;
                    submitButton.innerText = 'Quota atteint';
                } else {
                    statusContainer.innerHTML = `<p>Analyses restantes : ${remaining} / ${maxAnalyses}</p>`;
                    submitButton.disabled = false;
                    submitButton.innerText = defaultButtonText;
                }
            } catch (error) {
                console.error('Error checking user status:', error);
                statusContainer.innerHTML = `<p style="color:red;">Impossible de vérifier votre statut de quota.</p>`;
                submitButton.disabled = true; // Disable if we can't verify status
                submitButton.innerText = 'Erreur de vérification';
            }
        }

        function animateScore(finalScore) {
            const scoreCircle = document.querySelector('.score-circle');
            const scoreValueElement = document.getElementById('score-value');
            let currentScore = 0;
            const duration = 1500; // ms
            const stepTime = 20; // ms
            const steps = duration / stepTime;
            const increment = finalScore / steps;

            const interval = setInterval(() => {
                currentScore += increment;
                if (currentScore >= finalScore) {
                    currentScore = finalScore;
                    clearInterval(interval);
                }
                scoreValueElement.textContent = `${Math.round(currentScore)}%`;
                scoreCircle.style.background = `conic-gradient(#007bff ${currentScore * 3.6}deg, #e9ecef ${currentScore * 3.6}deg)`;
            }, stepTime);
        }

        document.getElementById('analysis-form').addEventListener('submit', async function(event) {
            event.preventDefault();

            const jobDescriptionText = document.getElementById('jobDescription').value;
            const jobDescriptionFile = document.getElementById('jobDescriptionFile').files.length > 0;

            if (!jobDescriptionText && !jobDescriptionFile) {
                alert("Veuillez coller la description de l'offre ou téléverser un fichier.");
                return;
            }

            const form = event.target;
            const formData = new FormData(form);
            const resultsContainer = document.getElementById('results-container');
            const analysisResult = document.getElementById('analysis-result');
            const keywordsResult = document.getElementById('keywords-result');
            const rewrittenCvResult = document.getElementById('rewritten-cv-result');
            const submitButton = form.querySelector('button[type="submit"]');

            submitButton.disabled = true;
            submitButton.innerText = 'Analyse en cours...';
            resultsContainer.style.display = 'none';

            try {
                const response = await fetch(form.action, {
                    method: form.method,
                    body: formData,
                });

                const data = await response.json();

                if (!response.ok) {
                    const errorText = data.error || `Une erreur est survenue: ${response.statusText}`;
                    throw new Error(errorText);
                }
                
                animateScore(data.score);

                analysisResult.innerHTML = marked.parse(data.analysis);
                keywordsResult.textContent = data.keywords;
                rewrittenCvResult.textContent = data.rewritten_cv;
                resultsContainer.style.display = 'block';

            } catch (error) {
                console.error('Erreur lors de l_analyse:', error);
                analysisResult.innerHTML = `<p style="color: red;">${error.message}</p>`;
                // Display results container to show the error message
                resultsContainer.style.display = 'block';
                // Clear other results fields
                document.getElementById('score-value').textContent = "0%";
                keywordsResult.textContent = "";
                rewrittenCvResult.textContent = "";

            } finally {
                // Re-check status to update the remaining count and button state
                checkUserStatus();
            }
        });

        document.getElementById('copy-cv-button').addEventListener('click', function() {
            const cvText = document.getElementById('rewritten-cv-result').textContent;
            navigator.clipboard.writeText(cvText).then(() => {
                this.innerText = 'Copié !';
                setTimeout(() => { this.innerText = 'Copier le CV'; }, 2000);
            });
        });

        document.getElementById('download-pdf-button').addEventListener('click', async function() {
            const cvText = document.getElementById('rewritten-cv-result').textContent;
            const downloadButton = this;

            downloadButton.disabled = true;
            downloadButton.innerText = 'Génération du PDF...';

            try {
                const response = await fetch('/download-pdf', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ cv_text: cvText })
                });

                if (!response.ok) {
                    const errorText = await response.text();
                    throw new Error(`Erreur du serveur: ${errorText}`);
                }

                const blob = await response.blob();
                const url = window.URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.style.display = 'none';
                a.href = url;
                a.download = 'cv-optimise.pdf';
                document.body.appendChild(a);
                a.click();
                window.URL.revokeObjectURL(url);
                document.body.removeChild(a);

            } catch (error) {
                console.error('Erreur de téléchargement:', error);
                alert('Le téléchargement a échoué. \n' + error.message);
            } finally {
                downloadButton.disabled = false;
                downloadButton.innerText = 'Télécharger en PDF';
            }
        });
    </script>

</body>
</html>
