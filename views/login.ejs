<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <!-- SEO Meta Tags -->
    <title>Connexion - Ubuntudigit Talent</title>
    <meta name="description" content="Connectez-vous à votre compte Ubuntudigit Talent pour accéder à notre analyseur de CV par IA et optimiser votre recherche d'emploi.">
    <meta name="robots" content="noindex, nofollow">

    <!-- Open Graph / Facebook -->
    <meta property="og:title" content="Connexion - Ubuntudigit Talent">
    <meta property="og:description" content="Accédez à votre compte pour utiliser nos outils d'optimisation de CV.">
    <meta property="og:image" content="https://res.cloudinary.com/dlqwxsufy/image/upload/v1773144575/Logo_ud_tarj6a.png">

    <!-- Twitter -->
    <meta property="twitter:title" content="Connexion - Ubuntudigit Talent">
    <meta property="twitter:description" content="Accédez à votre compte pour utiliser nos outils d'optimisation de CV.">
    <meta property="twitter:image" content="https://res.cloudinary.com/dlqwxsufy/image/upload/v1773144575/Logo_ud_tarj6a.png">

    <link rel="icon" href="https://res.cloudinary.com/dlqwxsufy/image/upload/v1773144575/Logo_ud_tarj6a.png" type="image/png">
    <link rel="stylesheet" href="/styles.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
</head>
<body class="auth-page">

    

    <main>
        <div class="auth-box">
            <div class="auth-header">
                <h2>Heureux de vous revoir !</h2>
                <p>Connectez-vous pour accéder à votre espace.</p>
            </div>

            <form action="/login" method="POST">
                <div class="form-group">
                    <label for="email">Email</label>
                    <input type="email" id="email" name="email" placeholder="exemple@email.com" required>
                </div>
                <div class="form-group">
                    <label for="password">Mot de passe</label>
                    <input type="password" id="password" name="password" placeholder="Votre mot de passe" required>
                </div>
                <% if (error) { %>
                    <p class="error-message" style="text-align:center; margin-bottom: 1rem;">Email ou mot de passe incorrect.</p>
                <% } %>
                <button type="submit" class="cta-button">Se connecter</button>
            </form>

            <div class="auth-footer">
                <p>Vous n'avez pas de compte ? <a href="/register">Inscrivez-vous</a></p>
            </div>
        </div>
    </main>

    

    <script src="/script.js"></script>

</body>
</html>
