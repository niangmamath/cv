<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Analyse de CVs pour Recruteurs - Ubuntudigit Talent</title>
    <link rel="icon" href="https://res.cloudinary.com/dlqwxsufy/image/upload/v1773144575/Logo_ud_tarj6a.png" type="image/png">
    <link rel="stylesheet" href="/styles.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
</head>
<body class="recruiter-page">

    <%- include('partials/header') %>

    <main class="container">
        <section class="analysis-form-section">
            <h2>Lancer une nouvelle analyse</h2>
            <p class="subtitle">Importez les CVs de vos candidats et l'offre d'emploi pour obtenir un classement basé sur la compatibilité.</p>
            
            <div id="user-status-container" class="user-status-container"></div>

            <form id="recruiter-form" action="/analyze-resumes" method="POST" enctype="multipart/form-data">
                <div class="form-group">
                    <label for="jobDescription">Description de l'offre d'emploi</label>
                    <textarea id="jobDescription" name="jobDescription" rows="8" placeholder="Copiez et collez ici la description du poste..."></textarea>
                    <p style="text-align:center; margin: 1rem 0; color: #777;">OU</p>
                    <label for="jobDescriptionFile">Téléversez une description de poste (PDF, TXT)</label>
                    <input type="file" id="jobDescriptionFile" name="jobDescriptionFile" accept=".pdf,.txt">
                </div>
                <div class="form-group">
                    <label for="cv-files">CV des candidats (multiples fichiers acceptés)</label>
                    <input type="file" id="cv-files" name="cvs" multiple accept=".pdf,.doc,.docx" required>
                </div>
                 <div class="privacy-notice">
                    <i class="fas fa-lock"></i>
                    <span>Pour garantir votre confidentialité, vos documents sont analysés de manière sécurisée et ne sont jamais stockés sur nos serveurs.</span>
                </div>
                <button type="submit">Analyser les CVs</button>
            </form>
        </section>

        <section class="results-section" style="display:none;">
            <div class="results-header">
                <h2>Résultats de l'analyse</h2>
                <button id="download-results-pdf"><i class="fas fa-download"></i> Télécharger les résultats en PDF</button>
            </div>
            <div id="results-container">
                <!-- Les résultats seront injectés ici -->
            </div>
        </section>
    </main>

    <%- include('partials/footer') %>

    <script src="/script.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            checkUserStatus();
        });

        async function checkUserStatus() {
            const statusContainer = document.getElementById('user-status-container');
            const submitButton = document.querySelector('#recruiter-form button[type="submit"]');
            const defaultButtonText = 'Analyser les CVs';

            try {
                const response = await fetch('/api/user-status');
                if (!response.ok) throw new Error('Could not fetch user status.');
                
                const data = await response.json();
                const { analysisCount, maxAnalyses } = data;
                const remaining = maxAnalyses - analysisCount;

                if (remaining <= 0) {
                    statusContainer.innerHTML = `
                        <p class="limit-reached-message">
                            <i class="fas fa-exclamation-triangle"></i>
                            Vous avez utilisé toutes vos analyses gratuites (${analysisCount}/${maxAnalyses}).
                            <a href="https://wa.me/212783346308" target="_blank">Contactez-nous sur WhatsApp</a> pour passer à un plan supérieur.
                        </p>
                    `;
                    submitButton.disabled = true;
                    submitButton.innerText = 'Quota atteint';
                } else {
                    statusContainer.innerHTML = `<p>Analyses restantes : ${remaining} / ${maxAnalyses}</p>`;
                    submitButton.disabled = false;
                    submitButton.innerText = defaultButtonText;
                }
            } catch (error) {
                console.error('Error checking user status:', error);
                statusContainer.innerHTML = `<p style="color:red;">Impossible de vérifier votre statut de quota.</p>`;
                submitButton.disabled = true; // Disable if we can't verify status
                submitButton.innerText = 'Erreur de vérification';
            }
        }

        const form = document.getElementById('recruiter-form');
        const analysisFormSection = document.querySelector('.analysis-form-section');
        const resultsSection = document.querySelector('.results-section');
        const resultsContainer = document.getElementById('results-container');
        const submitButton = form.querySelector('button[type="submit"]');
        let analysisResults = [];

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const jobDescriptionText = document.getElementById('jobDescription').value;
            const jobDescriptionFile = document.getElementById('jobDescriptionFile').files.length > 0;

            if (!jobDescriptionText && !jobDescriptionFile) {
                alert("Veuillez coller la description de l'offre ou téléverser un fichier.");
                return;
            }

            const formData = new FormData(form);
            submitButton.disabled = true;
            submitButton.innerText = 'Analyse en cours...';
            resultsSection.style.display = 'none';

            try {
                const response = await fetch('/analyze-resumes', {
                    method: 'POST',
                    body: formData
                });

                const data = await response.json();

                if (!response.ok) {
                    throw new Error(data.error || "Une erreur s'est produite lors de l'analyse.");
                }

                analysisResults = data;
                
                analysisFormSection.style.display = 'none';
                resultsSection.style.display = 'block';

                resultsContainer.innerHTML = '';

                if (analysisResults.length === 0) {
                    resultsContainer.innerHTML = '<p>Aucun CV analysé ou tous les CV étaient invalides.</p>';
                } else {
                    analysisResults.forEach(result => {
                        const resultElement = document.createElement('div');
                        resultElement.classList.add('result-card');
                        resultElement.innerHTML = `
                            <div class="result-card-header">
                                <span class="rank">#${result.rank}</span>
                                <h3 class="filename">${result.filename}</h3>
                                <div class="score-dial" style="--score: ${result.score}">
                                    <span>${result.score}%</span>
                                </div>
                            </div>
                            <div class="result-card-body">
                                <button class="toggle-details-btn">Voir les détails</button>
                                <div class="analysis-details" style="display: none;">
                                    <h4>Détails de l\'analyse</h4>
                                    <div class="strengths">
                                        <h5><i class="fas fa-check-circle"></i> Points Forts</h5>
                                        <p>${result.strengths || 'Aucun point fort notable détecté.'}</p>
                                    </div>
                                    <div class="weaknesses">
                                        <h5><i class="fas fa-times-circle"></i> Points Faibles</h5>
                                        <p>${result.weaknesses || 'Aucun point faible notable détecté.'}</p>
                                    </div>
                                     ${result.error ? `<p class=\"error-message\">Erreur: ${result.error}</p>` : ''}
                                </div>
                            </div>
                        `;
                        resultsContainer.appendChild(resultElement);
                    });
                }

            } catch (error) {
                console.error(error);
                alert(error.message);
                 resultsSection.style.display = 'block';
                 resultsContainer.innerHTML = `<p style="color:red;">${error.message}</p>`;
            } finally {
                checkUserStatus();
            }
        });

        resultsContainer.addEventListener('click', (e) => {
            if (e.target.classList.contains('toggle-details-btn')) {
                const details = e.target.nextElementSibling;
                if (details.style.display === 'none') {
                    details.style.display = 'block';
                    e.target.textContent = 'Masquer les détails';
                } else {
                    details.style.display = 'none';
                    e.target.textContent = 'Voir les détails';
                }
            }
        });

        document.getElementById('download-results-pdf').addEventListener('click', async function() {
            const downloadButton = this;
            downloadButton.disabled = true;
            downloadButton.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Génération du PDF...';

            const jobDescription = document.getElementById('jobDescription').value;

            try {
                const response = await fetch('/download-recruiter-results-pdf', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ 
                        results: analysisResults, 
                        jobDescription: jobDescription
                    })
                });

                if (!response.ok) {
                    const errorText = await response.text();
                    throw new Error(`Erreur du serveur: ${errorText}`);
                }

                const blob = await response.blob();
                const url = window.URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.style.display = 'none';
                a.href = url;
                a.download = 'resultats-analyse-cv.pdf';
                document.body.appendChild(a);
                a.click();
                window.URL.revokeObjectURL(url);
                document.body.removeChild(a);

            } catch (error) {
                console.error('Erreur de téléchargement:', error);
                alert('Le téléchargement a échoué. \n' + error.message);
            } finally {
                downloadButton.disabled = false;
                downloadButton.innerHTML = '<i class="fas fa-download"></i> Télécharger les résultats en PDF';
            }
        });

    </script>
</body>
</html>
