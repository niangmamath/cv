<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <!-- SEO Meta Tags -->
    <title>Inscription - Ubuntudigit Talent</title>
    <meta name="description" content="Créez votre compte gratuit sur Ubuntudigit Talent pour commencer à optimiser votre CV avec notre analyseur intelligent et décrocher l'emploi de vos rêves.">
    <meta name="robots" content="noindex, nofollow">

    <!-- Open Graph / Facebook -->
    <meta property="og:title" content="Inscription - Ubuntudigit Talent">
    <meta property="og:description" content="Créez votre compte pour accéder à nos outils d'optimisation de CV.">
    <meta property="og:image" content="https://res.cloudinary.com/dlqwxsufy/image/upload/v1773144575/Logo_ud_tarj6a.png">

    <!-- Twitter -->
    <meta property="twitter:title" content="Inscription - Ubuntudigit Talent">
    <meta property="twitter:description" content="Créez votre compte pour accéder à nos outils d'optimisation de CV.">
    <meta property="twitter:image" content="https://res.cloudinary.com/dlqwxsufy/image/upload/v1773144575/Logo_ud_tarj6a.png">

    <link rel="icon" href="https://res.cloudinary.com/dlqwxsufy/image/upload/v1773144575/Logo_ud_tarj6a.png" type="image/png">
    <link rel="stylesheet" href="/styles.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
</head>
<body class="auth-page">

    

    <main>
        <div class="auth-box">
            <div class="auth-header">
                <h2>Créer votre compte</h2>
                <p>Rejoignez-nous et optimisez votre carrière dès aujourd'hui.</p>
            </div>

            <form action="/register" method="POST">
                 <div class="form-group">
                    <label for="username">Nom d'utilisateur</label>
                    <input type="text" id="username" name="username" placeholder="Choisissez un nom d'utilisateur" required>
                </div>
                <div class="form-group">
                    <label for="email">Email</label>
                    <input type="email" id="email" name="email" placeholder="exemple@email.com" required>
                </div>
                <div class="form-group">
                    <label for="password">Mot de passe</label>
                    <input type="password" id="password" name="password" placeholder="Créez un mot de passe sécurisé" required>
                </div>
                <div class="form-group">
                    <label for="role">Vous êtes un...</label>
                    <select id="role" name="role">
                        <option value="job_seeker" selected>Candidat</option>
                        <option value="recruiter">Recruteur</option>
                    </select>
                </div>
                 <% if (error) { %>
                    <p class="error-message" style="text-align:center; margin-bottom: 1rem;">Une erreur est survenue. Veuillez réessayer.</p>
                <% } %>
                <button type="submit" class="cta-button">Créer mon compte</button>
            </form>

            <div class="auth-footer">
                <p>Vous avez déjà un compte ? <a href="/login">Connectez-vous</a></p>
            </div>
        </div>
    </main>

   

    <script src="/script.js"></script>

</body>
</html>
